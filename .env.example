# =============================================================
#  CMS — Environment configuration
#  Copy this file to .env and fill in the values marked CHANGE_ME
# =============================================================

# -----------------------------------------------------------
# DATABASE (required)
# -----------------------------------------------------------

# Full PostgreSQL connection string.
#
# Option A — Docker-managed PostgreSQL (--profile localdb):
#   Use the service name "db" as the host. Change only the password.
#   postgresql+psycopg2://cms:CHANGE_ME@db:5432/cmsdb
#
# Option B — External PostgreSQL on the same host as Docker:
#   Containers cannot reach the host via "localhost" — use the Docker
#   bridge gateway IP instead. Find it with:
#     ip route | grep docker0 | awk '{print $9}'
#   Typically 172.17.0.1. Then set:
#     postgresql+psycopg2://cms:CHANGE_ME@172.17.0.1:5432/cmsdb
#
#   PostgreSQL must also be configured to accept connections from Docker:
#
#   1. Allow TCP connections in postgresql.conf
#      (usually /etc/postgresql/<version>/main/postgresql.conf):
#        listen_addresses = '*'
#      Then reload: sudo systemctl reload postgresql
#
#   2. Allow the Docker subnet in pg_hba.conf
#      (usually /etc/postgresql/<version>/main/pg_hba.conf):
#        host  cmsdb  cms  172.17.0.0/16  scram-sha-256
#      Then reload: sudo systemctl reload postgresql
#
#   3. Open port 5432 for the Docker subnet in the host firewall.
#
#      If using UFW:
#        sudo ufw allow from 172.17.0.0/16 to any port 5432
#        sudo ufw reload
#
#      If using firewalld:
#        sudo firewall-cmd --permanent --add-rich-rule=\
#          'rule family=ipv4 source address=172.17.0.0/16 port protocol=tcp port=5432 accept'
#        sudo firewall-cmd --reload
#
#      Symptom: "Connection refused" means PostgreSQL is not listening on
#      that interface (check steps 1-2). "Connection timed out" means the
#      firewall is dropping the packet (fix step 3).
#
#   IMPORTANT — docker-compose uses its own bridge network, not docker0:
#      "docker compose up" creates a project network (e.g. docker_default)
#      with its own subnet, separate from the default Docker bridge (docker0 /
#      172.17.0.0/16). The gateway seen by containers is typically 172.18.0.1
#      or higher — NOT 172.17.0.1.
#
#      Find the real gateway with:
#        sudo docker network inspect docker_default | grep -A5 "IPAM"
#
#      Use that gateway IP in CMS_DB_URL and repeat steps 1-3 for that
#      subnet (e.g. 172.18.0.0/16). Steps 1-3 must be done for the actual
#      compose network subnet, not the docker0 subnet.
#
# Option C — External PostgreSQL on a separate server:
#   Use the server's hostname or IP directly:
#   postgresql+psycopg2://user:password@db-host:5432/dbname
CMS_DB_URL=postgresql+psycopg2://cms:CHANGE_ME@db:5432/cmsdb

# Only needed when using --profile localdb.
# Must match the password used in CMS_DB_URL above.
POSTGRES_USER=cms
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=cmsdb

# -----------------------------------------------------------
# SECURITY (required)
# -----------------------------------------------------------

# A random 16-byte hex key used to protect session cookies.
# Generate one with:
#   python3 -c 'from cmscommon import crypto; print(crypto.get_hex_random_key())'
# NEVER leave the example value in a production deployment.
CMS_SECRET_KEY=CHANGE_ME_16_BYTE_HEX

# -----------------------------------------------------------
# FIRST-TIME SETUP (required on first deploy, optional after)
# -----------------------------------------------------------

# Credentials for the initial admin account.
# Used by cmsSetupDB on first run. Ignored if an admin already exists.
# After the first deploy these values are no longer needed and can be removed.
CMS_ADMIN_USER=CHANGE_ME
CMS_ADMIN_PASSWORD=CHANGE_ME

# -----------------------------------------------------------
# CONTEST (required after importing a contest)
# -----------------------------------------------------------

# Numeric ID of the contest to serve.
# You can find this in the Admin interface after importing your contest.
CMS_CONTEST_ID=1

# -----------------------------------------------------------
# HTTP PORTS (optional — defaults shown)
# -----------------------------------------------------------

# Port for the Contest Web Server (contestants log in here).
CMS_CWS_HTTP_PORT=8888

# Port for the Admin Web Server (contest administration).
CMS_AWS_HTTP_PORT=8889

# Port for the Ranking Web Server (public scoreboard).
CMS_RWS_HTTP_PORT=8890

# -----------------------------------------------------------
# SCALING (optional — defaults shown)
# -----------------------------------------------------------

# Number of Contest Web Server instances to run.
# Use more than 1 when you have a load balancer (e.g. nginx) in front.
# Each instance listens on CMS_CWS_HTTP_PORT, CMS_CWS_HTTP_PORT+1, etc.
CMS_CWS_COUNT=1

# Number of Worker processes for grading submissions.
# Increase this if you have multiple CPU cores available.
CMS_WORKER_COUNT=1

# -----------------------------------------------------------
# INTERNAL RPC PORTS (optional — change only if there is a conflict)
# -----------------------------------------------------------

# Base RPC port for Contest Web Server shards (each shard uses port+shard).
CMS_CWS_RPC_PORT=21000

# RPC port for the Admin Web Server.
CMS_AWS_RPC_PORT=21100

# -----------------------------------------------------------
# REVERSE PROXY (optional)
# -----------------------------------------------------------

# IP address the web servers listen on.
# 0.0.0.0 means all interfaces (needed when behind a reverse proxy).
CMS_LISTEN_ADDRESS=0.0.0.0

# Number of reverse proxy hops before CMS receives the request.
# Set to 1 if you have nginx or another proxy in front of CMS.
# This is needed for CMS to log the real contestant IP addresses.
CMS_NUM_PROXIES_USED=0

# -----------------------------------------------------------
# RANKING WEB SERVER CREDENTIALS (optional)
# -----------------------------------------------------------

# Username and password used by CMS to push scores to the Ranking server.
CMS_RWS_USERNAME=rws
CMS_RWS_PASSWORD=CHANGE_ME

# -----------------------------------------------------------
# DIAGNOSTICS (optional)
# -----------------------------------------------------------

# Set to true to write debug-level entries to the service log files.
CMS_LOG_DEBUG=false

# -----------------------------------------------------------
# TELEGRAM BOT (optional)
# -----------------------------------------------------------

# Bot token issued by @BotFather.
CMS_TELEGRAM_BOT_TOKEN=

# Numeric ID of the Telegram chat/group where the bot posts.
CMS_TELEGRAM_CHAT_ID=

# -----------------------------------------------------------
# LOGGING (optional — defaults shown)
# -----------------------------------------------------------

# Maximum size of each Docker log file before rotation.
# Use Docker size units: 500m = 500 MB, 1g = 1 GB.
CMS_LOG_MAX_SIZE=500m

# Number of rotated log files to keep (total = MAX_SIZE × MAX_FILES).
# Default: 10 files × 500m = 5 GB max on disk.
CMS_LOG_MAX_FILES=10
