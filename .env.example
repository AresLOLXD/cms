# =============================================================
#  CMS — Environment configuration
#  Copy this file to .env and fill in the values marked CHANGE_ME
# =============================================================

# -----------------------------------------------------------
# DATABASE (required)
# -----------------------------------------------------------

# Full PostgreSQL connection string.
#
# If you are using --profile localdb (Docker-managed Postgres),
# change only the password and leave the rest as-is:
#   postgresql+psycopg2://cms:CHANGE_ME@db:5432/cmsdb
#
# If you are using an external database server:
#   postgresql+psycopg2://user:password@your-host:5432/dbname
CMS_DB_URL=postgresql+psycopg2://cms:CHANGE_ME@db:5432/cmsdb

# Only needed when using --profile localdb.
# Must match the password used in CMS_DB_URL above.
POSTGRES_USER=cms
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=cmsdb

# -----------------------------------------------------------
# SECURITY (required)
# -----------------------------------------------------------

# A random 16-byte hex key used to protect session cookies.
# Generate one with:
#   python3 -c 'from cmscommon import crypto; print(crypto.get_hex_random_key())'
# NEVER leave the example value in a production deployment.
CMS_SECRET_KEY=CHANGE_ME_16_BYTE_HEX

# -----------------------------------------------------------
# CONTEST (required after importing a contest)
# -----------------------------------------------------------

# Numeric ID of the contest to serve.
# You can find this in the Admin interface after importing your contest.
CMS_CONTEST_ID=1

# -----------------------------------------------------------
# HTTP PORTS (optional — defaults shown)
# -----------------------------------------------------------

# Port for the Contest Web Server (contestants log in here).
CMS_CWS_HTTP_PORT=8888

# Port for the Admin Web Server (contest administration).
CMS_AWS_HTTP_PORT=8889

# Port for the Ranking Web Server (public scoreboard).
CMS_RWS_HTTP_PORT=8890

# -----------------------------------------------------------
# SCALING (optional — defaults shown)
# -----------------------------------------------------------

# Number of Contest Web Server instances to run.
# Use more than 1 when you have a load balancer (e.g. nginx) in front.
# Each instance listens on CMS_CWS_HTTP_PORT, CMS_CWS_HTTP_PORT+1, etc.
CMS_CWS_COUNT=1

# Number of Worker processes for grading submissions.
# Increase this if you have multiple CPU cores available.
CMS_WORKER_COUNT=1

# -----------------------------------------------------------
# INTERNAL RPC PORTS (optional — change only if there is a conflict)
# -----------------------------------------------------------

# Base RPC port for Contest Web Server shards (each shard uses port+shard).
CMS_CWS_RPC_PORT=21000

# RPC port for the Admin Web Server.
CMS_AWS_RPC_PORT=21100

# -----------------------------------------------------------
# REVERSE PROXY (optional)
# -----------------------------------------------------------

# IP address the web servers listen on.
# 0.0.0.0 means all interfaces (needed when behind a reverse proxy).
CMS_LISTEN_ADDRESS=0.0.0.0

# Number of reverse proxy hops before CMS receives the request.
# Set to 1 if you have nginx or another proxy in front of CMS.
# This is needed for CMS to log the real contestant IP addresses.
CMS_NUM_PROXIES_USED=0

# -----------------------------------------------------------
# RANKING WEB SERVER CREDENTIALS (optional)
# -----------------------------------------------------------

# Username and password used by CMS to push scores to the Ranking server.
CMS_RWS_USERNAME=rws
CMS_RWS_PASSWORD=CHANGE_ME

# -----------------------------------------------------------
# DIAGNOSTICS (optional)
# -----------------------------------------------------------

# Set to true to write debug-level entries to the service log files.
CMS_LOG_DEBUG=false
